# Copy to .env and fill in values.

# Local dev uses SQLite:
# DATABASE_URL="file:./dev.db"

# Production (Neon Postgres) — get this from neon.tech dashboard:
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/playtora?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
AUTH_TRUST_HOST=true

# Email (Resend). Get a key at https://resend.com/api-keys
# If unset, emails are no-op'd (logged) — useful in dev.
RESEND_API_KEY=""
EMAIL_FROM="Playtora <noreply@playtora.app>"
EMAIL_REPLY_TO="hello@playtora.app"

# Vercel Cron secret — set the same value in Vercel Project Env.
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# Public site URL (used for canonicals + email links).
NEXT_PUBLIC_SITE_URL="https://playtora.vercel.app"
