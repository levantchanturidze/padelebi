// Playtora — multi-sport venue marketplace data model.
//
// Phase 1 rename: Club → Venue, Court → Facility, CourtSchedule → FacilitySchedule.
// Existing tables are preserved via @@map / @map so production data is not touched;
// only a new Sport table and a Facility.sportId column are added.
//
// Enum-like fields stay as Strings (validated in app code via src/lib/enums.ts) and
// list/object fields are JSON-encoded Strings, so the same schema works on SQLite
// (local dev) and Postgres (prod).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sport {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  icon      String // lucide icon name
  category  String // RACQUET | TEAM | INDIVIDUAL | FITNESS | WATER
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  facilities Facility[]

  @@index([category, isActive])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("PLAYER") // PLAYER | CLUB_ADMIN | PLATFORM_ADMIN
  phone        String?
  skillLevel   String? // BEGINNER | INTERMEDIATE | ADVANCED | PRO
  /// Preferred locale for transactional emails (ka | en).
  locale       String   @default("ka")
  /// Optional saved "home base" — used as a fallback position on venue
  /// listings when the user hasn't granted the browser's live geolocation.
  /// homeLat and homeLng are only meaningful together.
  homeAddress  String?
  homeLat      Float?
  homeLng      Float?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  venues      Venue[]              @relation("VenueOwner")
  bookings    Booking[]
  reviews     Review[]
  favorites   Favorite[]
  resetTokens PasswordResetToken[]
}

model Venue {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String   @default("")
  address      String
  city         String
  /// Sub-city neighbourhood (Saburtalo, Vake, etc.). Free-text; the filter
  /// shows existing values via datalist suggestions.
  district     String?
  lat          Float?
  lng          Float?
  photos       String   @default("[]") // JSON string[] of image URLs
  amenities    String   @default("[]") // JSON string[] of amenity keys
  openingHours String   @default("{}") // JSON: { "0": {open, close}, ... } by weekday
  status       String   @default("PENDING") // PENDING | APPROVED | SUSPENDED
  ownerId      String
  createdAt    DateTime @default(now())

  owner      User       @relation("VenueOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  facilities Facility[]
  reviews    Review[]
  favorites  Favorite[]

  @@index([city])
  @@index([status])
  @@map("Club")
}

model Facility {
  id              String   @id @default(cuid())
  venueId         String   @map("clubId")
  sportId         String
  name            String
  /// Cross-sport surface taxonomy used by the /venues filter:
  /// SYNTHETIC | PARQUET | CLAY | HARD | GRASS | CARPET | SAND. Nullable —
  /// granular sport-specific surface variants live in `attributes`.
  surfaceCategory String?
  /// Sport-neutral metadata, JSON-encoded. Shape is defined per-sport in lib/sports/<slug>.ts.
  attributes      String   @default("{}")
  /// How this facility is booked: TIME_SLOT (courts/pitches), CLASS (group sessions), DROP_IN (day pass).
  bookingModel    String   @default("TIME_SLOT")
  /// Max simultaneous attendees: 1 for a court, N for a class, large for a gym.
  capacity        Int      @default(1)
  isIndoor        Boolean  @default(false)
  pricePerHourGEL Int      @default(40)
  isActive        Boolean  @default(true)
  photos          String   @default("[]") // JSON string[]
  createdAt       DateTime @default(now())

  venue     Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sport     Sport              @relation(fields: [sportId], references: [id])
  schedules FacilitySchedule[]
  bookings  Booking[]
  blackouts Blackout[]
  classes   ClassSession[]

  @@index([venueId])
  @@index([sportId, isActive])
  @@map("Court")
}

/// A scheduled group session on a CLASS-mode facility. Each session has its
/// own capacity, time and price; bookings reference the session, not raw time.
model ClassSession {
  id          String   @id @default(cuid())
  facilityId  String
  title       String
  startTime   DateTime
  endTime     DateTime
  capacity    Int
  priceGEL    Int
  instructor  String?
  isCancelled Boolean  @default(false)
  createdAt   DateTime @default(now())

  facility Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([facilityId, startTime])
}

// Weekly availability template per facility used to generate bookable slots.
model FacilitySchedule {
  id           String @id @default(cuid())
  facilityId   String @map("courtId")
  dayOfWeek    Int // 0 = Sunday ... 6 = Saturday
  openMinutes  Int // minutes from midnight, e.g. 480 = 08:00
  closeMinutes Int // e.g. 1320 = 22:00
  slotMinutes  Int    @default(60)

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([facilityId, dayOfWeek])
  @@map("CourtSchedule")
}

model Booking {
  id             String   @id @default(cuid())
  facilityId     String   @map("courtId")
  userId         String
  /// Populated only when bookingModel = CLASS — the booked session.
  classSessionId String?
  /// Number of attendees this booking covers (e.g. booking 2 seats in a class). Default 1.
  attendees      Int      @default(1)
  startTime      DateTime
  endTime        DateTime
  /// Final price paid (already discounted). Original = priceGEL + discountAmountGEL.
  priceGEL       Int
  /// Redeemed code, if any. Snapshotted so historical bookings survive code deletion.
  discountCodeId    String?
  /// Amount taken off the subtotal in GEL. 0 or null when no code was applied.
  discountAmountGEL Int?
  status         String   @default("CONFIRMED") // PENDING | CONFIRMED | CANCELLED
  paymentStatus  String   @default("UNPAID") // UNPAID | PAID | REFUNDED
  notes          String?
  /// Null until the 24h reminder cron sends an email. Idempotency guard.
  reminderSentAt DateTime?
  createdAt      DateTime @default(now())

  facility     Facility      @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  classSession ClassSession? @relation(fields: [classSessionId], references: [id])
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id])

  @@index([facilityId, startTime])
  @@index([userId])
  @@index([classSessionId])
  @@index([discountCodeId])
}

/// Promotional discount codes redeemable at booking checkout. `usedCount` is
/// bumped inside the booking transaction, so we can enforce `maxUses` without
/// a separate redemption table. Per-user caps are enforced by counting live
/// (non-CANCELLED) bookings that carry the code.
model DiscountCode {
  id            String   @id @default(cuid())
  code          String   @unique
  /// PERCENT | FIXED
  type          String
  /// PERCENT: 1–100 (whole percent). FIXED: GEL taken off the subtotal.
  value         Int
  /// Total redemptions permitted across all users. Null = unlimited.
  maxUses       Int?
  usedCount     Int      @default(0)
  /// Max redemptions per user. Default 1. Null = unlimited.
  perUserMax    Int?     @default(1)
  /// Minimum booking subtotal (GEL) that qualifies. Null = no floor.
  minAmountGEL  Int?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  bookings Booking[]

  @@index([isActive, expiresAt])
}

// Time ranges blocked from booking (maintenance, private events).
model Blackout {
  id         String   @id @default(cuid())
  facilityId String   @map("courtId")
  startTime  DateTime
  endTime    DateTime
  reason     String?
  createdAt  DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId, startTime])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  venueId   String   @map("clubId")
  userId    String
  rating    Int // 1..5
  comment   String   @default("")
  createdAt DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([venueId, userId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  venueId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([userId])
}
